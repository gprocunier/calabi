---
apiVersion: operators.coreos.com/v1
kind: OperatorGroup
metadata:
  name: openshift-nmstate
  namespace: {{ openshift_post_install_nmstate_namespace }}
spec:
  targetNamespaces:
    - {{ openshift_post_install_nmstate_namespace }}
---
apiVersion: operators.coreos.com/v1alpha1
kind: Subscription
metadata:
  name: {{ openshift_post_install_nmstate_subscription_name }}
  namespace: {{ openshift_post_install_nmstate_namespace }}
spec:
  channel: {{ openshift_post_install_nmstate_channel }}
  installPlanApproval: Automatic
  name: {{ openshift_post_install_nmstate_subscription_name }}
  source: {{ openshift_post_install_nmstate_source }}
  sourceNamespace: {{ openshift_post_install_nmstate_source_namespace }}
