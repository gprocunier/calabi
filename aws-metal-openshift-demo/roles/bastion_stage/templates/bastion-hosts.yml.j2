---
all:
  children:
    aws_metal:
      hosts:
        {{ bastion_stage_hypervisor_host }}:
          ansible_host: "{{ bastion_stage_hypervisor_target_host }}"
          ansible_user: "{{ bastion_stage_hypervisor_target_user }}"
          ansible_ssh_private_key_file: >-
            {{ bastion_client.project_root }}/secrets/id_ed25519
          ansible_ssh_common_args: >-
            -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null
