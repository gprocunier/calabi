---
apiVersion: operators.coreos.com/v1
kind: OperatorGroup
metadata:
  name: {{ openshift_post_install_odf_local_storage_operatorgroup_name }}
  namespace: {{ openshift_post_install_odf_local_storage_namespace }}
spec:
  targetNamespaces:
    - {{ openshift_post_install_odf_local_storage_namespace }}
---
apiVersion: operators.coreos.com/v1alpha1
kind: Subscription
metadata:
  name: {{ openshift_post_install_odf_local_storage_subscription_name }}
  namespace: {{ openshift_post_install_odf_local_storage_namespace }}
spec:
  channel: {{ openshift_post_install_odf_local_storage_channel }}
  installPlanApproval: Automatic
  name: {{ openshift_post_install_odf_local_storage_package_name }}
  source: {{ openshift_post_install_odf_local_storage_source }}
  sourceNamespace: {{ openshift_post_install_odf_local_storage_source_namespace }}
