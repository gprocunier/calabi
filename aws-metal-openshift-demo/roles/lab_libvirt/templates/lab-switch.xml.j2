<network>
  <name>{{ lab_switch_name }}</name>
  <forward mode='bridge'/>
  <bridge name='{{ lab_bridge_name }}'/>
  <virtualport type='openvswitch'/>
  <portgroup name='mgmt-access' default='yes'>
    <vlan>
      <tag id='100'/>
    </vlan>
  </portgroup>
  <portgroup name='ocp-trunk'>
    <vlan trunk='yes'>
      <tag id='200'/>
      <tag id='201'/>
      <tag id='202'/>
    </vlan>
  </portgroup>
  <portgroup name='data300-access'>
    <vlan>
      <tag id='300'/>
    </vlan>
  </portgroup>
  <portgroup name='data301-access'>
    <vlan>
      <tag id='301'/>
    </vlan>
  </portgroup>
  <portgroup name='data302-access'>
    <vlan>
      <tag id='302'/>
    </vlan>
  </portgroup>
</network>
