---
apiVersion: operators.coreos.com/v1alpha1
kind: Subscription
metadata:
  name: {{ openshift_post_install_pipelines_subscription_name }}
  namespace: {{ openshift_post_install_pipelines_operator_namespace }}
spec:
  channel: {{ openshift_post_install_pipelines_channel }}
  installPlanApproval: Automatic
  name: {{ openshift_post_install_pipelines_package_name }}
  source: {{ openshift_post_install_pipelines_source }}
  sourceNamespace: {{ openshift_post_install_pipelines_source_namespace }}
