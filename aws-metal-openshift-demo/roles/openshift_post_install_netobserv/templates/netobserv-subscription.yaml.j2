---
apiVersion: operators.coreos.com/v1
kind: OperatorGroup
metadata:
  name: openshift-netobserv-operator
  namespace: {{ openshift_post_install_netobserv_operator_namespace }}
---
apiVersion: operators.coreos.com/v1alpha1
kind: Subscription
metadata:
  name: {{ openshift_post_install_netobserv_subscription_name }}
  namespace: {{ openshift_post_install_netobserv_operator_namespace }}
spec:
  channel: {{ openshift_post_install_netobserv_channel }}
  installPlanApproval: Automatic
  name: {{ openshift_post_install_netobserv_subscription_name }}
  source: {{ openshift_post_install_netobserv_source }}
  sourceNamespace: {{ openshift_post_install_netobserv_source_namespace }}
