---
apiVersion: operators.coreos.com/v1alpha1
kind: Subscription
metadata:
  name: {{ openshift_post_install_web_terminal_subscription_name }}
  namespace: {{ openshift_post_install_web_terminal_namespace }}
spec:
  channel: {{ openshift_post_install_web_terminal_channel }}
  installPlanApproval: Automatic
  name: {{ openshift_post_install_web_terminal_package_name }}
  source: {{ openshift_post_install_web_terminal_source }}
  sourceNamespace: {{ openshift_post_install_web_terminal_source_namespace }}
