---
apiVersion: workspace.devfile.io/v1alpha2
kind: DevWorkspaceTemplate
metadata:
  annotations:
    controller.devfile.io/allow-import-from: '*'
  labels:
    console.openshift.io/terminal: "true"
  name: web-terminal-tooling
  namespace: {{ openshift_post_install_web_terminal_namespace }}
spec:
  components:
    - name: web-terminal-tooling
      container:
        args:
          - tail
          - -f
          - /dev/null
        cpuLimit: 400m
        cpuRequest: 100m
        image: {{ openshift_post_install_web_terminal_custom_tooling_pullspec }}
        memoryLimit: 512Mi
        memoryRequest: 128Mi
        mountSources: false
        sourceMapping: /projects
